__pycache__/
data/
encoding.egg-info

# 语言模型特征缓存（体积过大，可重新提取，不进 git）
cache/

# 编码模型输出结果（大文件，可重新生成，不进 git）
# 忽略 results/ 下所有内容，但保留目录约定说明 README，使其随仓库走
results/*
!results/README.md
# 旧的 results_dir 名（已统一为 results/），保险忽略防误提交
thesis_results/
build/

# 预训练语义模型数据（大文件，随原始数据包下载，不进 git）
em_data/

# M6 图表/表格产物（可由 scripts/m6_figures.py / m6_tables.py 从服务器结果重新生成，
# 二进制图片不进 git；来源说明见 manuscript/README.md）
figures/*

# Python 编译文件
*.pyc
*.pyo
.DS_Store
*Zone.Identifier
.claude/
